# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Rust
*.rs text eol=lf
*.toml text eol=lf

# Scripts
*.sh text eol=lf
*.bash text eol=lf

# Documents
*.txt text eol=lf
LICENSE text eol=lf
README.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.db binary

# Export ignore
.gitattributes export-ignore
.gitignore export-ignore
.github/ export-ignore
